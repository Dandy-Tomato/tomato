pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    environment {
        APP_DIR      = 'backend'
        GIT_URL      = 'https://lab.ssafy.com/s14-bigdata-recom-sub1/S14P21A508.git'
        GIT_BRANCH   = '*/CI/develop'

        DOCKER_IMAGE = 'nnnnnara/tomato-backend'

        EC2_HOST     = 'j14a508.p.ssafy.io'
        EC2_USER     = 'ubuntu'
        DEPLOY_DIR   = '/home/ubuntu/tomato'
        COMPOSE_FILE = 'docker-compose.prod.yml'
    }

    stages {
        stage('Check Build Environment') {
            steps {
                sh '''
                    set -eux
                    whoami
                    echo "PATH=$PATH"
                    echo "JAVA_HOME=${JAVA_HOME:-}"
                    /opt/java/openjdk/bin/java -version
                    command -v docker
                    docker --version
                    ls -l /var/run/docker.sock || true
                '''
            }
        }

        stage('Checkout') {
            steps {
                deleteDir()
                checkout([$class: 'GitSCM',
                    branches: [[name: env.GIT_BRANCH]],
                    userRemoteConfigs: [[
                        url: env.GIT_URL,
                        credentialsId: 'gitlab-http-creds'
                    ]]
                ])
            }
        }

        stage('Build Backend') {
            steps {
                dir("${env.APP_DIR}") {
                    sh '''
                        set -eux

                        echo "[INFO] whoami / pwd"
                        whoami
                        pwd
                        ls -ld .
                        ls -l

                        export JAVA_HOME=/opt/java/openjdk
                        export PATH=$JAVA_HOME/bin:$PATH

                        mkdir -p ~/.gradle
                        printf '%s\n' \
                            'org.gradle.java.installations.auto-detect=false' \
                            'org.gradle.java.installations.paths=/opt/java/openjdk' \
                            > ~/.gradle/gradle.properties

                        echo "[INFO] Java version"
                        java -version

                        echo "[INFO] Check gradle tasks"
                        chmod +x gradlew
                        ./gradlew tasks --all | grep -E 'bootJar|jar' || true

                        echo "[INFO] Build executable jar"
                        ./gradlew clean bootJar -x test --no-daemon --stacktrace

                        echo "[INFO] Verify artifact"
                        ls -al build || true
                        ls -al build/libs || true
                        find . -maxdepth 5 -type f \\( -name '*.jar' -o -name '*.war' \\) | sort || true

                        test -d build/libs
                        test -n "$(find build/libs -maxdepth 1 -type f -name '*.jar' ! -name '*-plain.jar' -print -quit)"
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir("${env.APP_DIR}") {
                    sh '''
                        set -eux
                        ls -al build/libs
                        find build/libs -maxdepth 1 -type f -name '*.jar' | sort
                        docker build -t ${DOCKER_IMAGE}:latest -t ${DOCKER_IMAGE}:${BUILD_NUMBER} .
                    '''
                }
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKERHUB_USERNAME',
                    passwordVariable: 'DOCKERHUB_TOKEN'
                )]) {
                    sh '''
                        set -eux

                        echo "[INFO] Docker Hub login"
                        echo "$DOCKERHUB_TOKEN" | docker login -u "$DOCKERHUB_USERNAME" --password-stdin

                        echo "[INFO] Push images"
                        docker push ${DOCKER_IMAGE}:latest
                        docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}

                        docker logout
                    '''
                }
            }
        }

        stage('Deploy to EC2') {
            steps {
                sshagent(credentials: ['ec2-prod-ssh']) {
                    sh '''
                        set -eux

                        ssh -o StrictHostKeyChecking=no ${EC2_USER}@${EC2_HOST} "
                            set -eux
                            cd ${DEPLOY_DIR}

                            echo '[INFO] Pull new backend image'
                            BACKEND_IMAGE=${DOCKER_IMAGE}:${BUILD_NUMBER} \
                            docker compose -f ${COMPOSE_FILE} pull backend

                            echo '[INFO] Recreate backend container'
                            BACKEND_IMAGE=${DOCKER_IMAGE}:${BUILD_NUMBER} \
                            docker compose -f ${COMPOSE_FILE} up -d backend

                            echo '[INFO] Remove dangling images'
                            docker image prune -f
                        "
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'CI/CD pipeline succeeded.'
        }
        failure {
            echo 'CI/CD pipeline failed.'
        }
        always {
            deleteDir()
        }
    }
}