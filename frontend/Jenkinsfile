pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
        skipDefaultCheckout(true)
    }

    environment {
        APP_DIR = 'frontend'
        DOCKER_IMAGE = 'nnnnnara/tomato-frontend'
        DOCKER_TAG = "${env.BUILD_NUMBER}"
        DEPLOY_DIR = '/home/ubuntu/tomato'
        COMPOSE_FILE = 'docker-compose.prod.yml'
        EC2_HOST = 'j14a508.p.ssafy.io'
        EC2_USER = 'ubuntu'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                sh '''
                    echo "=== repo root ==="
                    pwd
                    ls -al
                    echo "=== frontend ==="
                    ls -al ${APP_DIR}
                '''
            }
        }

        stage('Prepare Env') {
            steps {
                withCredentials([file(credentialsId: 'frontend-env-production', variable: 'ENV_FILE')]) {
                    sh '''
                        cp "$ENV_FILE" ${APP_DIR}/.env.production
                        echo "=== frontend after env copy ==="
                        ls -al ${APP_DIR}
                        test -f ${APP_DIR}/.env.production
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                        docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} .
                        docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_IMAGE}:latest
                    '''
                }
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh '''
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                        docker push ${DOCKER_IMAGE}:${DOCKER_TAG}
                        docker push ${DOCKER_IMAGE}:latest
                        docker logout
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                sshagent(credentials: ['ec2-prod-ssh']) {
                    sh '''
                        ssh -o StrictHostKeyChecking=no ${EC2_USER}@${EC2_HOST} "
                            cd ${DEPLOY_DIR} &&
                            export FRONTEND_IMAGE=${DOCKER_IMAGE}:${DOCKER_TAG} &&
                            docker compose -f ${COMPOSE_FILE} pull frontend &&
                            docker compose -f ${COMPOSE_FILE} up -d frontend
                        "
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Frontend CI/CD success'
        }
        failure {
            echo 'Frontend CI/CD failed'
        }
    }
}