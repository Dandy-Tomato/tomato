import groovy.json.JsonOutput

/*
 * =========================
 * Mattermost 알림용 헬퍼 함수
 * =========================
 */

def buildGitCommitUrl(String gitUrl, String commitSha) {
    if (!gitUrl?.trim() || !commitSha?.trim()) {
        return ''
    }

    def base = gitUrl.trim().replaceAll(/\.git$/, '')
    return "${base}/-/commit/${commitSha}"
}

def detectBranch() {
    if (env.BRANCH_NAME?.trim()) {
        return env.BRANCH_NAME.trim()
    }

    if (env.GIT_LOCAL_BRANCH?.trim()) {
        return env.GIT_LOCAL_BRANCH.trim()
    }

    if (env.GIT_BRANCH?.trim()) {
        return env.GIT_BRANCH.replaceFirst(/^origin\//, '').trim()
    }

    if (fileExists('.git')) {
        def symbolic = sh(
            script: "git symbolic-ref --short -q HEAD || true",
            returnStdout: true
        ).trim()

        if (symbolic) {
            return symbolic
        }

        def remoteBranch = sh(
            script: "git branch -r --contains HEAD | sed 's/^ *//' | head -n 1 || true",
            returnStdout: true
        ).trim()

        if (remoteBranch) {
            return remoteBranch.replaceFirst(/^origin\//, '')
        }
    }

    return 'unknown'
}

def resolveBranch() {
    def cached = env.PIPELINE_BRANCH?.trim()
    if (cached && cached != 'HEAD') return cached

    return detectBranch()
}

def resolvePusherMention() {
    def cached = env.PIPELINE_MENTION?.trim()
    if (cached) return cached

    def pusher = env.GIT_PUSHER_USERNAME?.trim()
    if (pusher) {
        return "@${pusher}"
    }

    try {
        if (fileExists('.git')) {
            return sh(
                script: "git --no-pager show -s --format='%an <%ae>' HEAD",
                returnStdout: true
            ).trim()
        }
    } catch (Exception e) {
        echo "작성자 정보를 가져오지 못했습니다: ${e.message}"
    }

    return 'Unknown'
}

def markStage(String stageName) {
    env.LAST_STAGE = stageName
    echo "[STAGE] LAST_STAGE = ${env.LAST_STAGE}"
}

def sendMMNotify(boolean success, Map info) {
    def titleLine = success
        ? "## :jenkins1: AI CI/CD 성공 :happy_cat:"
        : "## :jenkins5: AI CI/CD 실패 :omgham:"

    def lines = []

    if (info.mention) {
        lines << "**작성자**: ${info.mention}"
    }

    if (info.branch) {
        lines << "**브랜치**: `${info.branch}`"
    }

    if (info.image) {
        lines << "**이미지**: `${info.image}`"
    }

    if (info.server) {
        lines << "**배포 서버**: `${info.server}`"
    }

    if (info.stage) {
        lines << "**실패/현재 단계**: `${info.stage}`"
    }

    if (info.commit?.msg) {
        def commitLine = info.commit?.url
            ? "[${info.commit.msg}](${info.commit.url})"
            : info.commit.msg
        lines << "**커밋**: ${commitLine}"
    }

    if (info.buildUrl) {
        lines << "**빌드 상세**: [Details](${info.buildUrl})"
    }

    if (info.details) {
        lines << "**비고**: ${info.details}"
    }

    def text = "${titleLine}\n" + (lines ? ("\n" + lines.join("\n")) : "")

    writeFile(
        file: 'payload.json',
        text: JsonOutput.toJson([
            text      : text,
            username  : "Jenkins",
            icon_emoji: ":rocket:"
        ])
    )

    withCredentials([string(credentialsId: 'mattermost-webhook', variable: 'MM_WEBHOOK')]) {
        sh '''
            set -eux
            curl -sS -f -X POST \
              -H 'Content-Type: application/json' \
              --data-binary @payload.json \
              "$MM_WEBHOOK"
        '''
    }
}

pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    environment {
        APP_DIR         = 'ai'
        GIT_URL         = 'https://lab.ssafy.com/s14-bigdata-recom-sub1/S14P21A508.git'
        CHECKOUT_BRANCH = '*/develop'

        AI_IMAGE        = 'nnnnnara/tomato-ai'

        EC2_HOST        = 'j14a508.p.ssafy.io'
        EC2_USER        = 'ubuntu'
        DEPLOY_DIR      = '/home/ubuntu/tomato'
        COMPOSE_FILE    = 'docker-compose.ai.prod.yml'
    }

    stages {
        stage('Check Build Environment') {
            steps {
                script {
                    markStage('Check Build Environment')
                }
                sh '''
                    set -eux
                    whoami
                    pwd
                    echo "PATH=$PATH"
                    command -v docker
                    docker --version
                    python3 --version || true
                    ls -l /var/run/docker.sock || true
                '''
            }
        }

        stage('Checkout') {
            steps {
                script {
                    markStage('Checkout')
                }

                deleteDir()

                checkout([
                    $class: 'GitSCM',
                    branches: [[name: env.CHECKOUT_BRANCH]],
                    userRemoteConfigs: [[
                        url: env.GIT_URL,
                        credentialsId: 'gitlab-http-creds'
                    ]]
                ])

                script {
                    env.PIPELINE_BRANCH = detectBranch()

                    env.PIPELINE_COMMIT_SHA = sh(
                        script: "git rev-parse HEAD",
                        returnStdout: true
                    ).trim()

                    env.PIPELINE_COMMIT_MSG = sh(
                        script: "git log -1 --pretty=%s",
                        returnStdout: true
                    ).trim()

                    def pusher = env.GIT_PUSHER_USERNAME?.trim()
                    if (pusher) {
                        env.PIPELINE_MENTION = "@${pusher}"
                    } else {
                        env.PIPELINE_MENTION = sh(
                            script: "git --no-pager show -s --format='%an <%ae>' HEAD",
                            returnStdout: true
                        ).trim()
                    }

                    env.PIPELINE_COMMIT_URL = buildGitCommitUrl(env.GIT_URL, env.PIPELINE_COMMIT_SHA)

                    echo "Collected metadata:"
                    echo "- branch: ${env.PIPELINE_BRANCH}"
                    echo "- commit: ${env.PIPELINE_COMMIT_SHA}"
                    echo "- mention: ${env.PIPELINE_MENTION}"
                }
            }
        }

        stage('Validate AI Files') {
            steps {
                script {
                    markStage('Validate AI Files')
                }

                dir("${env.APP_DIR}") {
                    sh '''
                        set -eux

                        test -f Dockerfile
                        test -f requirements.txt
                        test -f app/main.py
                        test -f app/settings.py
                        test -f app/consumer/recommendation_event_consumer.py

                        test -d app
                        test -d app/consumer

                        echo "[INFO] AI project structure is valid"
                        find app -maxdepth 2 -type f | sort
                    '''
                }
            }
        }

        stage('Build AI Image') {
            steps {
                script {
                    markStage('Build AI Image')
                }

                dir("${env.APP_DIR}") {
                    sh '''
                        set -eux

                        docker build \
                          -t ${AI_IMAGE}:latest \
                          -t ${AI_IMAGE}:${BUILD_NUMBER} \
                          .
                    '''
                }
            }
        }

        stage('Push AI Image') {
            steps {
                script {
                    markStage('Push AI Image')
                }

                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKERHUB_USERNAME',
                    passwordVariable: 'DOCKERHUB_TOKEN'
                )]) {
                    sh '''
                        set -eux

                        echo "$DOCKERHUB_TOKEN" | docker login -u "$DOCKERHUB_USERNAME" --password-stdin

                        docker push ${AI_IMAGE}:latest
                        docker push ${AI_IMAGE}:${BUILD_NUMBER}

                        docker logout
                    '''
                }
            }
        }

        stage('Deploy to EC2') {
            steps {
                script {
                    markStage('Deploy to EC2')
                }

                sshagent(credentials: ['ec2-prod-ssh']) {
                    sh("""
                        set -eux

                        ssh -o StrictHostKeyChecking=no ${EC2_USER}@${EC2_HOST} 'bash -se' <<'REMOTE_SCRIPT'
if [ ! -d ${DEPLOY_DIR} ]; then
  echo "[ERROR] Deploy directory not found: ${DEPLOY_DIR}"
  exit 1
fi

cd ${DEPLOY_DIR}

if [ ! -f .env ]; then
  echo "[ERROR] ${DEPLOY_DIR}/.env not found"
  exit 1
fi

if [ ! -f ${COMPOSE_FILE} ]; then
  echo "[ERROR] ${DEPLOY_DIR}/${COMPOSE_FILE} not found"
  exit 1
fi

if ! docker network ls --format '{{.Name}}' | grep -qx 'tomato-net'; then
  echo "[ERROR] docker network 'tomato-net' not found"
  exit 1
fi

if grep -q '^AI_IMAGE=' .env; then
  sed -i 's|^AI_IMAGE=.*|AI_IMAGE=${AI_IMAGE}:${BUILD_NUMBER}|' .env
else
  echo 'AI_IMAGE=${AI_IMAGE}:${BUILD_NUMBER}' >> .env
fi

echo '[INFO] Current AI_IMAGE in .env'
grep '^AI_IMAGE=' .env

echo '[INFO] Pull new AI image'
docker compose --env-file .env -f ${COMPOSE_FILE} pull ai-api ai-consumer

echo '[INFO] Recreate ai-api and ai-consumer'
docker compose --env-file .env -f ${COMPOSE_FILE} up -d --force-recreate ai-api ai-consumer

echo '[INFO] Compose status'
docker compose --env-file .env -f ${COMPOSE_FILE} ps

echo '[INFO] AI API recent logs'
docker compose --env-file .env -f ${COMPOSE_FILE} logs --tail=50 ai-api || true

echo '[INFO] AI Consumer recent logs'
docker compose --env-file .env -f ${COMPOSE_FILE} logs --tail=50 ai-consumer || true

echo '[INFO] Remove dangling images'
docker image prune -f
REMOTE_SCRIPT
                    """.stripIndent())
                }
            }
        }

        stage('Verify Deployment') {
            steps {
                script {
                    markStage('Verify Deployment')
                }

                sshagent(credentials: ['ec2-prod-ssh']) {
                    sh("""
                        set -eux

                        ssh -o StrictHostKeyChecking=no ${EC2_USER}@${EC2_HOST} 'bash -se' <<'REMOTE_SCRIPT'
cd ${DEPLOY_DIR}

echo '[INFO] Final compose status'
docker compose --env-file .env -f ${COMPOSE_FILE} ps

echo '[INFO] Verify ai-api container is running'
docker ps --filter "name=tomato-ai-api" --filter "status=running"

echo '[INFO] Verify ai-consumer container is running'
docker ps --filter "name=tomato-ai-consumer" --filter "status=running"

echo '[INFO] Last ai-api logs'
docker compose --env-file .env -f ${COMPOSE_FILE} logs --tail=30 ai-api || true

echo '[INFO] Last ai-consumer logs'
docker compose --env-file .env -f ${COMPOSE_FILE} logs --tail=30 ai-consumer || true
REMOTE_SCRIPT
                    """.stripIndent())
                }
            }
        }
    }

    post {
        success {
            script {
                def buildInfo = [
                    mention : env.PIPELINE_MENTION?.trim() ?: resolvePusherMention(),
                    branch  : env.PIPELINE_BRANCH?.trim() ?: resolveBranch(),
                    buildUrl: env.BUILD_URL,
                    image   : "${env.AI_IMAGE}:${env.BUILD_NUMBER}",
                    server  : env.EC2_HOST,
                    stage   : env.LAST_STAGE?.trim() ?: 'START',
                    commit  : [
                        msg: env.PIPELINE_COMMIT_MSG?.trim() ?: 'N/A',
                        url: env.PIPELINE_COMMIT_URL?.trim() ?: ''
                    ]
                ]

                echo 'AI image build and deployment succeeded.'
                sendMMNotify(true, buildInfo)
            }
        }

        failure {
            script {
                def buildInfo = [
                    mention : env.PIPELINE_MENTION?.trim() ?: resolvePusherMention(),
                    branch  : env.PIPELINE_BRANCH?.trim() ?: resolveBranch(),
                    buildUrl: env.BUILD_URL,
                    image   : "${env.AI_IMAGE}:${env.BUILD_NUMBER}",
                    server  : env.EC2_HOST,
                    stage   : env.LAST_STAGE?.trim() ?: 'START',
                    commit  : [
                        msg: env.PIPELINE_COMMIT_MSG?.trim() ?: 'N/A',
                        url: env.PIPELINE_COMMIT_URL?.trim() ?: ''
                    ],
                    details : "빌드 상세 링크에서 실패 원인을 확인하세요."
                ]

                echo 'AI image build or deployment failed.'
                sendMMNotify(false, buildInfo)
            }
        }

        always {
            deleteDir()
        }
    }
}